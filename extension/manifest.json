{
  "manifest_version": 3,
  "name": "VitouLens AI",
  "version": "0.1.0",
  "description": "Read English. Understand in Khmer. Learn faster.",
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
