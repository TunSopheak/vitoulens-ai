{
  "manifest_version": 3,
  "name": "VitouLens AI",
  "version": "0.1.0",
  "description": "Read English. Understand in Khmer. Learn faster.",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "VitouLens AI"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}